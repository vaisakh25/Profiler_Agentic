# Copy to .env and fill values before deployment.
# Never commit real API keys or tokens.

# ================================================
# CREDENTIALS AND SECRETS ONLY
# Non-secret configuration lives in config.yml
# ================================================

# API keys
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# LangSmith observability API key
LANGSMITH_API_KEY=

# PostgreSQL profiling credentials (external databases to profile)
PROFILER_PG_HOST=
PROFILER_PG_USER=
PROFILER_PG_PASSWORD=
PROFILER_PG_DBNAME=

# MinIO credentials
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

# Optional cloud connector credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AZURE_STORAGE_CONNECTION_STRING=
GOOGLE_APPLICATION_CREDENTIALS=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
