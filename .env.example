# Copy to .env and fill values before deployment.
# Never commit real API keys or tokens.

# -----------------------------
# Agentic Profiler Environment
# -----------------------------

# File system
PROFILER_DATA_DIR=./data/files
PROFILER_UPLOAD_DIR=./data/uploads
PROFILER_OUTPUT_DIR=./data/output
PROFILER_VECTOR_STORE_DIR=./data/output/chroma_store

# Security (used for encrypted connector credential storage)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROFILER_SECRET_KEY=

# Server
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080
CONNECTOR_MCP_PORT=8081
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s  %(levelname)-8s  %(name)s  %(message)s

# Docker entrypoint service toggles
ENABLE_PROFILER_MCP=1
ENABLE_CONNECTOR_MCP=1
ENABLE_WEB_UI=0
WEB_PORT=8501
# Optional explicit URLs for web mode; defaults are based on MCP_PORT/CONNECTOR_MCP_PORT
WEB_MCP_URL=
WEB_CONNECTOR_MCP_URL=

# Upload / performance
MAX_UPLOAD_SIZE_MB=500
UPLOAD_TTL_HOURS=1
MAX_PARALLEL_WORKERS=4

# DuckDB tuning
DUCKDB_MEMORY_LIMIT=512MB
DUCKDB_THREADS=4

# LLM defaults
LLM_PROVIDER=openai
LLM_MODEL=

# Optional stronger model for REDUCE / META-REDUCE
REDUCE_LLM_PROVIDER=
REDUCE_LLM_MODEL=

# Optional per-provider default model aliases
DEFAULT_MODEL_ANTHROPIC=claude-sonnet-4-20250514
DEFAULT_MODEL_OPENAI=gpt-4o
DEFAULT_MODEL_GOOGLE=gemini-3.1-flash-lite-preview
DEFAULT_MODEL_GROQ=llama-3.3-70b-versatile

# LLM provider keys (set the ones you use)
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional provider request-per-minute limits (0 = unlimited)
GOOGLE_RPM_LIMIT=15
GROQ_RPM_LIMIT=30
OPENAI_RPM_LIMIT=500
ANTHROPIC_RPM_LIMIT=50

# LLM timeouts (seconds)
LLM_TIMEOUT=60
LLM_MAP_TIMEOUT=30
LLM_REDUCE_TIMEOUT=120

# Enrichment map/reduce tuning
ENRICHMENT_MAP_WORKERS=12
ENRICHMENT_MAP_TOKEN_BUDGET=2000
ENRICHMENT_MAP_TOKEN_BUDGET_MAX=16000
ENRICHMENT_REDUCE_TOP_K=15
ENRICHMENT_REDUCE_TOKEN_BUDGET=12000
ENRICHMENT_CLUSTER_TARGET_SIZE=15
ENRICHMENT_PER_CLUSTER_TOKEN_BUDGET=6000
ENRICHMENT_META_REDUCE_TOKEN_BUDGET=8000
COLUMN_AFFINITY_THRESHOLD=0.65
ENRICHMENT_BATCH_SIZE=20

# NVIDIA embeddings
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v1
NVIDIA_EMBED_BATCH_SIZE=64
NVIDIA_EMBED_TIMEOUT=60

# OpenAI-compatible endpoint overrides (optional)
OPENAI_BASE_URL=
OPENAI_API_BASE=

# PostgreSQL (optional chat/session persistence)
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=profiler
POSTGRES_PASSWORD=
POSTGRES_DB=profiler
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# Cloud connector credentials (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=

AZURE_STORAGE_CONNECTION_STRING=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

GOOGLE_APPLICATION_CREDENTIALS=

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=

# Connector timeout
CONNECTOR_TIMEOUT=30

# -----------------------------
# Deployment Metadata (optional)
# -----------------------------
# Used by external deployment tooling; app runtime ports still use MCP_PORT/CONNECTOR_MCP_PORT.
APP_PORT=8080
GIT_URL=
GIT_USERNAME=
GIT_TOKEN=
GIT_BRANCH=
