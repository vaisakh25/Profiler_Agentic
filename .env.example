# Copy to .env and fill values before deployment.
# Never commit real API keys or tokens.

# -----------------------------
# Connection + Credential Overrides
# Keep only ports/endpoints, DB credentials, and API keys here.
# Non-secret runtime tuning lives in config.yml.
# -----------------------------

# Service ports (connection settings)
MCP_PORT=8080
CONNECTOR_MCP_PORT=8081
WEB_PORT=8501
APP_PORT=8080
GATEWAY_PORT=9050

# Runtime defaults (can override config.yml)
MAX_UPLOAD_SIZE_MB=500

# MCP endpoint routing for web mode (single-container direct ports)
WEB_MCP_URL=http://localhost:8080/sse
WEB_CONNECTOR_MCP_URL=http://localhost:8081/sse

# For gateway mode (reverse proxy on 9050), use these instead:
# WEB_MCP_URL=http://localhost:9050/mcp/file/sse
# WEB_CONNECTOR_MCP_URL=http://localhost:9050/mcp/connector/sse

# For Kivor Kubernetes DNS routing, use these instead:
# WEB_MCP_URL=http://profiler-mcp:9050/sse
# WEB_CONNECTOR_MCP_URL=http://profiler-mcp:9051/sse

# API keys
# IMPORTANT: one key=value per env entry. Do not append another KEY= in a value.
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
NVIDIA_API_KEY=

# PostgreSQL Profiling (external databases to profile)
PROFILER_PG_HOST=
PROFILER_PG_PORT=5432
PROFILER_PG_USER=
PROFILER_PG_PASSWORD=
PROFILER_PG_DBNAME=

# OpenAI-compatible endpoint connections
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_API_BASE=https://integrate.api.nvidia.com/v1

# Optional cloud connector credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MinIO credentials and endpoint (runtime defaults in config.yml)
MINIO_ENDPOINT_URL=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=

AZURE_STORAGE_CONNECTION_STRING=
GOOGLE_APPLICATION_CREDENTIALS=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
