# Copy to .env and fill values before deployment.
# Never commit real API keys.

# Storage and runtime paths
PROFILER_DATA_DIR=./data/files
PROFILER_UPLOAD_DIR=./data/uploads
PROFILER_OUTPUT_DIR=./data/output
PROFILER_VECTOR_STORE_DIR=./data/output/chroma_store

# Optional encryption key for persisted credentials
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROFILER_SECRET_KEY=

# MCP server config
MCP_TRANSPORT=sse
MCP_HOST=0.0.0.0
MCP_PORT=8080
CONNECTOR_MCP_PORT=8081
LOG_LEVEL=INFO

# Upload and performance limits
MAX_UPLOAD_SIZE_MB=500
UPLOAD_TTL_HOURS=1
MAX_PARALLEL_WORKERS=4

# Default LLM selection
LLM_PROVIDER=anthropic
LLM_MODEL=
REDUCE_LLM_PROVIDER=
REDUCE_LLM_MODEL=

# Provider API keys (set at least one based on selected provider)
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# NVIDIA embeddings (required for enrichment vector store + semantic search)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBEDDING_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v1
NVIDIA_EMBED_BATCH_SIZE=64
NVIDIA_EMBED_TIMEOUT=60

# Optional custom OpenAI-compatible base URLs
OPENAI_BASE_URL=
OPENAI_API_BASE=

# Optional PostgreSQL chat/session persistence
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=profiler
POSTGRES_PASSWORD=
POSTGRES_DB=profiler

# Connector timeouts
CONNECTOR_TIMEOUT=30
