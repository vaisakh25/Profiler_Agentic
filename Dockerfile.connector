FROM python:3.11-slim

WORKDIR /app

# Copy build manifests
COPY pyproject.toml requirements-connector.txt ./

# ============================================================================
# LIGHTWEIGHT BUILD: Connector MCP server does NOT need ML stack
# No torch, transformers, sentence-transformers, langchain-huggingface, chromadb
# This reduces image size by ~2-3GB and build memory by ~1GB
# ============================================================================
RUN pip install --no-cache-dir --prefer-binary \
    pandas==2.3.3 \
    numpy==2.4.2 \
    fastapi==0.128.8 \
    "uvicorn[standard]==0.40.0" \
    duckdb==1.4.4 \
    "mcp[cli]==1.26.0" \
    "psycopg[binary,pool]==3.2.3" \
    pyarrow==21.0.0 \
    openpyxl==3.1.5 \
    python-dotenv==1.2.1 \
    psutil==6.1.0 \
    xlrd==2.0.1 \
    chardet==5.2.0 \
    typing-extensions

# Copy the application
COPY . .

# Create necessary directories
RUN mkdir -p /data/uploads /data/output

# Create a non-root user
RUN useradd -m -u 1000 appuser && \
    chown -R appuser:appuser /app /data

USER appuser

# Expose connector MCP port
EXPOSE 8081

# Set entrypoint to run connector MCP server
ENTRYPOINT ["python", "-m", "file_profiler.connectors"]

# Default command args
CMD ["--transport", "sse", "--host", "0.0.0.0", "--port", "8081"]
